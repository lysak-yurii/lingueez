<?xml version="1.0" encoding="utf-8"?>
<!--
  MSIX package manifest for the Microsoft Store build of Lingueez.

  This wraps the SAME PyInstaller onedir output (dist\Lingueez\, with Lingueez.exe
  at the package root) that the Inno Setup .exe installer uses — see packaging/msix/README.md.

  The Identity/Publisher/PublisherDisplayName values below come from Partner
  Center (Product management -> Product identity) and must match it exactly. Only
  {{VERSION}} is templated — CI substitutes a 4-part x.y.z.0 built from
  app/version.py APP_VERSION (see the "msix" steps in .github/workflows/release.yml).

  The Store re-signs the package on submission, so CI produces it UNSIGNED and no
  code-signing certificate is required.
-->
<Package
  xmlns="http://schemas.microsoft.com/appx/manifest/foundation/windows10"
  xmlns:uap="http://schemas.microsoft.com/appx/manifest/uap/windows10"
  xmlns:rescap="http://schemas.microsoft.com/appx/manifest/foundation/windows10/restrictedcapabilities"
  IgnorableNamespaces="uap rescap">

  <Identity
    Name="Lingueez.Lingueez"
    Publisher="CN=28779F39-F4FA-4661-B226-BEFACD1E833B"
    Version="{{VERSION}}"
    ProcessorArchitecture="x64" />

  <Properties>
    <DisplayName>Lingueez</DisplayName>
    <PublisherDisplayName>Lingueez</PublisherDisplayName>
    <Description>Study and grow your vocabulary across languages with spaced-repetition flashcards, read-aloud, and reading practice.</Description>
    <Logo>Assets\StoreLogo.png</Logo>
  </Properties>

  <Dependencies>
    <!-- 10.0.17763.0 = Windows 10 1809, the floor for full-trust MSIX desktop apps. -->
    <TargetDeviceFamily Name="Windows.Desktop" MinVersion="10.0.17763.0" MaxVersionTested="10.0.22621.0" />
  </Dependencies>

  <Resources>
    <Resource Language="en-US" />
    <Resource Language="uk-UA" />
  </Resources>

  <Applications>
    <Application Id="Lingueez" Executable="Lingueez.exe" EntryPoint="Windows.FullTrustApplication">
      <uap:VisualElements
        DisplayName="Lingueez"
        Description="Study and grow your vocabulary across languages."
        BackgroundColor="transparent"
        Square150x150Logo="Assets\Square150x150Logo.png"
        Square44x44Logo="Assets\Square44x44Logo.png">
        <uap:DefaultTile
          Wide310x150Logo="Assets\Wide310x150Logo.png"
          Square71x71Logo="Assets\Square71x71Logo.png"
          Square310x310Logo="Assets\Square310x310Logo.png" />
      </uap:VisualElements>
    </Application>
  </Applications>

  <Capabilities>
    <!-- The global Add-Word hotkey uses a system-wide low-level keyboard hook,
         which a packaged app can only install with full trust. This is a
         restricted capability and needs a one-line justification at submission. -->
    <rescap:Capability Name="runFullTrust" />
  </Capabilities>
</Package>
